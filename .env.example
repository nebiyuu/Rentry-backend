# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecom
DB_USER=postgres
DB_PASS=password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here

# Chapa Payment Configuration
CHAPA_SECRET_KEY=your-chapa-secret-key-here

# Email Configuration (for mailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Microservice Configuration - Related Products API
RELATED_PRODUCTS_API_URL=https://api.microservice.com/v1/products
RELATED_PRODUCTS_API_KEY=your-microservice-api-key-here
MICROSERVICE_TIMEOUT=5000
MICROSERVICE_SIMULATED_DELAY=100
RELATED_PRODUCTS_ALGORITHM=collaborative_filtering
RELATED_PRODUCTS_CONFIDENCE=0.85

# Testing/Development Flags
SIMULATE_MICROSERVICE_FAILURE=false
NODE_ENV=development

# Server Configuration
PORT=5000

# Admin Configuration (for seeding)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
